# DEV: /docs and /openapi.json are available only with Basic Auth.
# PROD: /docs, /openapi.json and /redoc return 404.
MODE=DEV
DOCS_USER=valid_user
DOCS_PASSWORD=valid_password

# JWT settings. Replace this value in a real project and never commit real secrets.
JWT_SECRET_KEY=change-this-secret-in-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# SQLite database file.
DB_PATH=kr3.sqlite3
